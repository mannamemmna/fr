# =============================================================================
# FR-BOT Configuration — copy to .env and fill in your values
# =============================================================================

# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Telegram Chat ID for all notifications (get yours from @userinfobot)
# All: auto events, errors, health, trade summaries. No /auto on needed.
NOTIFY_CHAT_ID=

# Paper Mode: "true" = simulated trading, "false" = real exchange trading
# Live trading requires BOTH PAPER_MODE=false AND LIVE_CONFIRM=true.
# Keep LIVE_CONFIRM=false unless you intentionally want real orders.
PAPER_MODE=true
LIVE_CONFIRM=false
PAPER_INITIAL_BALANCE=10000

# =============================================================================
# Exchange API Keys (required only when PAPER_MODE=false)
# =============================================================================

BYBIT_API_KEY=
BYBIT_API_SECRET=
KUCOIN_API_KEY=
KUCOIN_API_SECRET=
KUCOIN_API_PASSPHRASE=

# ─── Auto-scan ───
AUTO_SCAN_INTERVAL=60

# =============================================================================
# WebSocket (real-time market data) — replaces REST polling for prices/funding
# =============================================================================
# Heartbeat ping interval to prevent server timeout (seconds)
WS_HEARTBEAT_SEC=20

# Rate limiter for REST API calls (calls/second)
REST_RATE_LIMIT_PER_SEC=10

# Default leverage for /execute (1–20x)
DEFAULT_LEVERAGE=2

# Automation Engine
AUTO_MODE=false
AUTO_MAX_POSITIONS=1
AUTO_BALANCE_PER_LEG=1000
AUTO_LEVERAGE=3

# Waktu pencarian & delay
AUTO_ENTRY_WINDOW_MIN=30
AUTO_MONITOR_INTERVAL=0.5

# Threshold Entry & Exit (Automation Rules)
# LOOKING: hanya masuk kandidat jika Diff FR >= threshold ini
AUTO_DELTA_THRESHOLD=0.4

# DELAY: cancel entry jika Diff FR drop ke <= threshold
AUTO_DELAY_CANCEL_FUNDING_DIFF=0.2
# DELAY: entry (buka posisi) jika Price Spread <= threshold (0.0 = negatif/nol saja)
AUTO_DELAY_ENTRY_PRICE_SPREAD=0.0

# LIVE Tahap 1: tunggu Diff FR turun ke <= threshold dulu
AUTO_LIVE_CLOSE_FUNDING_DIFF=0.05
# LIVE Tahap 2: setelah Tahap 1 terpenuhi, close jika Price Spread >= threshold (0.0 = nol atau positif)
AUTO_LIVE_CLOSE_PRICE_SPREAD=0.0

AUTO_CLOSE_ON_RESTART=true

# =============================================================================
# Auto Rebalance
# =============================================================================
# Min ratio exchange kecil / total agar dianggap seimbang (default 40%/60%)
REBALANCE_THRESHOLD=0.40

# Paper mode: fee simulasi transfer (0.1%)
REBALANCE_PAPER_FEE_PCT=0.001

# Paper mode: delay simulasi transfer dalam detik
REBALANCE_PAPER_DELAY_SEC=5

# Live mode: interval polling cek saldo saat menunggu transfer manual (detik)
REBALANCE_CHECK_INTERVAL_SEC=60

# Live mode: aktifkan auto-transfer via withdrawal API (butuh withdrawal permission!)
# SANGAT HATI-HATI. Default false = notifikasi saja, user transfer manual.
REBALANCE_AUTO_TRANSFER=false
# If auto-rebalance is off, only notify (no auto transfer)


# ─── Hedge Integrity ───
# Jika satu exchange force-close (margin call), auto-close exchange satunya
# agar posisi tetap neutral (naked position = rugi besar)
HEDGE_EMERGENCY_OPEN=true
HEDGE_CHECK_INTERVAL_SEC=30
HEDGE_BALANCE_DROP_THRESHOLD=0.95

# ─── Live Fill Verification & Partial Fill Protection ───
# Retry placement order saat gagal (network error, rate limit)
LIVE_ORDER_PLACEMENT_MAX_RETRIES=3
LIVE_ORDER_PLACEMENT_RETRY_BASE_SEC=1.0
# Polling status fill setelah order ditempatkan
LIVE_FILL_POLL_INTERVAL_SEC=0.5
LIVE_FILL_POLL_TIMEOUT_SEC=10
# Partial fill: toleransi mismatch antar leg (2%) sebelum reconciliation
LIVE_PARTIAL_FILL_TOLERANCE_PCT=0.02
LIVE_PARTIAL_FILL_TOPUP_MAX_ATTEMPTS=2

# ─── Live Unrealized PnL ───
# Hitung floating PnL live dari mark price real-time. Matikan kalau banyak
# posisi terbuka & mulai kena rate limit REST.
LIVE_UNREALIZED_PNL_ENABLED=true

DB_PATH=fr-bot.db
# Top N in /top command
DEFAULT_TOP_N=10
