# =============================================================================
# FR-BOT Configuration — copy to .env and fill in your values
# =============================================================================

# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Telegram Chat ID for all notifications (get yours from @userinfobot)
# All: auto events, errors, health, trade summaries. No /auto on needed.
NOTIFY_CHAT_ID=

# Paper Mode: "true" = simulated trading, "false" = real exchange trading
# Live trading requires BOTH PAPER_MODE=false AND LIVE_CONFIRM=true.
# Keep LIVE_CONFIRM=false unless you intentionally want real orders.
PAPER_MODE=true
LIVE_CONFIRM=false
PAPER_INITIAL_BALANCE=1000

# =============================================================================
# Exchange API Keys (required only when PAPER_MODE=false)
# =============================================================================

BYBIT_API_KEY=
BYBIT_API_SECRET=
KUCOIN_API_KEY=
KUCOIN_API_SECRET=
KUCOIN_API_PASSPHRASE=

# ─── Auto-scan ───
AUTO_SCAN_INTERVAL=60

# =============================================================================
# WebSocket (real-time market data) — replaces REST polling for prices/funding
# =============================================================================
# Heartbeat ping interval to prevent server timeout (seconds)
WS_HEARTBEAT_SEC=20

# Rate limiter for REST API calls (calls/second)
REST_RATE_LIMIT_PER_SEC=10

# Max symbols subscribed on the public WS per exchange. Too many tickers on
# one connection causes disconnect loops. Lowered to 20 now that KuCoin
# uses TWO topic subscriptions per symbol (mark+funding, bid+ask) instead
# of one, keeping total topic count per connection well within the stable
# range.
MAX_WS_SUBSCRIPTIONS=20

# Default leverage for /execute (1–20x)
DEFAULT_LEVERAGE=2

# Automation Engine
AUTO_MODE=true
AUTO_MAX_POSITIONS=5
AUTO_BALANCE_PER_LEG=100
AUTO_LEVERAGE=2

# Waktu pencarian & delay
AUTO_ENTRY_WINDOW_MIN=30
AUTO_MONITOR_INTERVAL=0.5

# Threshold Entry & Exit (Automation Rules)
# LOOKING: hanya masuk kandidat jika Diff FR >= threshold ini
AUTO_DELTA_THRESHOLD=0.3

# DELAY: cancel entry jika Diff FR drop ke <= threshold
AUTO_DELAY_CANCEL_FUNDING_DIFF=0.25
# DELAY: entry (buka posisi) jika Price Spread <= threshold (0.0 = negatif/nol saja)
AUTO_DELAY_ENTRY_PRICE_SPREAD=-0.05

# LIVE Tahap 1: tunggu Diff FR turun ke <= threshold dulu
AUTO_LIVE_CLOSE_FUNDING_DIFF=0.05
# LIVE Tahap 2: setelah Tahap 1 terpenuhi, close jika Price Spread >= threshold (0.0 = nol atau positif)
AUTO_LIVE_CLOSE_PRICE_SPREAD=0.05

AUTO_CLOSE_ON_RESTART=true

# =============================================================================
# Auto Rebalance
# =============================================================================
# Min ratio exchange kecil / total agar dianggap seimbang (default 40%/60%)
REBALANCE_THRESHOLD=0.40

# Paper mode: fee simulasi transfer (0.1%)
REBALANCE_PAPER_FEE_PCT=0.001

# Paper mode: delay simulasi transfer dalam detik
REBALANCE_PAPER_DELAY_SEC=5

# Live mode: interval polling cek saldo saat menunggu transfer manual (detik)
REBALANCE_CHECK_INTERVAL_SEC=60

# DEPRECATED — no longer read by any code path. Live transfer is controlled by
# REBALANCE_LIVE_TRANSFER_ENABLED + REBALANCE_LIVE_DRY_RUN below. Kept here only
# so existing .env files with this set don't silently break; safe to delete.
REBALANCE_AUTO_TRANSFER=false

# ─── Live CEX→CEX Auto Withdrawal — REAL MONEY, READ BEFORE ENABLING ───
# 1. Test with REBALANCE_LIVE_DRY_RUN=true first (logs intended withdrawal, sends NOTHING).
# 2. Then test with a transfer at REBALANCE_MIN_TRANSFER_USD for a few cycles.
# 3. Only then raise REBALANCE_MAX_TRANSFER_USD and set REBALANCE_LIVE_DRY_RUN=false.
REBALANCE_LIVE_TRANSFER_ENABLED=false
REBALANCE_LIVE_DRY_RUN=true

REBALANCE_TOKEN=USDT
REBALANCE_NETWORK=TRON

# Deposit address MUST be copy-pasted from the exchange's own deposit page for
# the exact network above. Wrong network = permanent loss. No default provided.
REBALANCE_BYBIT_DEPOSIT_ADDRESS=
REBALANCE_KUCOIN_DEPOSIT_ADDRESS=
REBALANCE_BYBIT_DEPOSIT_MEMO=
REBALANCE_KUCOIN_DEPOSIT_MEMO=

REBALANCE_MIN_TRANSFER_USD=20
REBALANCE_MAX_TRANSFER_USD=500
REBALANCE_WITHDRAW_POLL_INTERVAL_SEC=15
REBALANCE_WITHDRAW_POLL_TIMEOUT_SEC=1800

# ─── Internal transfer after deposit (Bybit UTA 2.0 / KuCoin Futures) ───
# On-chain deposit confirmation can take minutes depending on network — TRON
# is usually fastest, ARBITRUM/BASE depend on L2 finality, BSC is quick too.
REBALANCE_DEPOSIT_POLL_INTERVAL_SEC=10
REBALANCE_DEPOSIT_POLL_TIMEOUT_SEC=1800
REBALANCE_INTERNAL_TRANSFER_POLL_INTERVAL_SEC=5
REBALANCE_INTERNAL_TRANSFER_POLL_TIMEOUT_SEC=600

# ─── Hedge Integrity ───
# Jika satu exchange force-close (margin call), auto-close exchange satunya
# agar posisi tetap neutral (naked position = rugi besar)
HEDGE_EMERGENCY_OPEN=true
HEDGE_CHECK_INTERVAL_SEC=5
HEDGE_BALANCE_DROP_THRESHOLD=0.95

# ─── Delisting Protection ───
# Cek pengumuman delisting Bybit & KuCoin secara berkala, blokir entry baru
# untuk simbol yang terdeteksi, dan alert kalau ada posisi terbuka terdampak.
DELISTING_MONITOR_ENABLED=true
DELISTING_CHECK_INTERVAL_SEC=3600
# HATI-HATI: auto-close posisi terbuka begitu delisting terdeteksi (bukan cuma
# alert). Default false — parsing judul itu best-effort, false positive bisa
# menutup posisi yang sebenarnya aman. Aktifkan hanya kalau paham risikonya.
AUTO_CLOSE_ON_DELISTING_DETECTED=false

# ─── Delisting Protection — in-memory cache TTL for automation loop ───
# Automation engine hits the DB less often by caching the blacklist set for
# this many seconds. Independent from DELISTING_CHECK_INTERVAL_SEC (which
# controls how often we poll exchanges for NEW announcements).
DELISTING_BLACKLIST_CACHE_TTL_SEC=30

# ─── Live Fill Verification & Partial Fill Protection ───
# Retry placement order saat gagal (network error, rate limit)
LIVE_ORDER_PLACEMENT_MAX_RETRIES=3
LIVE_ORDER_PLACEMENT_RETRY_BASE_SEC=1.0
# Polling status fill setelah order ditempatkan
LIVE_FILL_POLL_INTERVAL_SEC=0.5
LIVE_FILL_POLL_TIMEOUT_SEC=10
# Partial fill: toleransi mismatch antar leg (2%) sebelum reconciliation
LIVE_PARTIAL_FILL_TOLERANCE_PCT=0.01
LIVE_PARTIAL_FILL_TOPUP_MAX_ATTEMPTS=2

# ─── Live Unrealized PnL ───
# Hitung floating PnL live dari mark price real-time. Matikan kalau banyak
# posisi terbuka & mulai kena rate limit REST.
LIVE_UNREALIZED_PNL_ENABLED=true

# ─── Diff Interval Exit Strategy ───
# Max hold time (menit) untuk interval beda — force exit sebelum kena bleeding
LIVE_DIFF_HOLD_MAX_MINUTES=50

DB_PATH=fr-bot.db
# Top N in /top command
DEFAULT_TOP_N=10

# ─── Delisting Protection ───
# Cek pengumuman delisting Bybit & KuCoin secara berkala, blokir entry baru
# untuk simbol yang terdeteksi, dan alert kalau ada posisi terbuka terdampak.
DELISTING_MONITOR_ENABLED=true
DELISTING_CHECK_INTERVAL_SEC=3600
# HATI-HATI: auto-close posisi terbuka begitu delisting terdeteksi (bukan cuma
# alert). Default false — parsing judul itu best-effort, false positive bisa
# menutup posisi yang sebenarnya aman. Aktifkan hanya kalau paham risikonya.
AUTO_CLOSE_ON_DELISTING_DETECTED=false
