# =============================================================================
# FR-BOT Configuration — copy to .env and fill in your values
# =============================================================================

# Telegram Bot Token (from @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# Telegram Chat ID for all notifications (get yours from @userinfobot)
# All: auto events, errors, health, trade summaries. No /auto on needed.
NOTIFY_CHAT_ID=

# Paper Mode: "true" = simulated trading, "false" = real exchange trading
# Live trading requires BOTH PAPER_MODE=false AND LIVE_CONFIRM=true.
# Keep LIVE_CONFIRM=false unless you intentionally want real orders.
PAPER_MODE=true
LIVE_CONFIRM=false
PAPER_INITIAL_BALANCE=10000

# =============================================================================
# Exchange API Keys (required only when PAPER_MODE=false)
# =============================================================================

BYBIT_API_KEY=
BYBIT_API_SECRET=
KUCOIN_API_KEY=
KUCOIN_API_SECRET=
KUCOIN_API_PASSPHRASE=

# ─── Auto-scan ───
AUTO_SCAN_INTERVAL=60

# Default leverage for /execute (1–20x)
DEFAULT_LEVERAGE=2

# ─── Automation Config ───
AUTO_MODE=false
AUTO_SCAN_INTERVAL=60
AUTO_LEVERAGE=3
AUTO_BALANCE_PER_LEG=1000

# Waktu pencarian & delay
AUTO_ENTRY_WINDOW_MIN=30
AUTO_DELAY_CHECKS=10
AUTO_MONITOR_INTERVAL=0.5

# Threshold Entry & Exit (Automation Rules)
# Fase DELAY (Sebelum masuk): Batal jika price_spread > X atau funding_diff turun ke <= Y
AUTO_DELAY_CANCEL_PRICE_SPREAD=0.05
AUTO_DELAY_CANCEL_FUNDING_DIFF=0.2
# Fase LIVE (Sudah posisi): Close jika funding_diff turun ke <= X DAN price_spread <= Y
AUTO_LIVE_CLOSE_FUNDING_DIFF=0.05
AUTO_LIVE_CLOSE_PRICE_SPREAD=0.0
AUTO_ENTRY_WINDOW_MIN=30
AUTO_REVERSAL_THRESHOLD=0.0
AUTO_DELAY_CHECKS=6
AUTO_PRICE_SPREAD_MAX_DRIFT=0.05
AUTO_PREFER_SAME_INTERVAL=true

# Top N in /top command
DEFAULT_TOP_N=10
